# Anthropic API key for the diligence agent + eval judge
ANTHROPIC_API_KEY=sk-ant-...

# Model selection (defaults shown)
LP_DILIGENCE_MODEL=claude-sonnet-4-6
LP_DILIGENCE_JUDGE_MODEL=claude-haiku-4-5-20251001

# Embedding provider: 'local' uses sentence-transformers, 'openai' uses OpenAI embeddings
LP_DILIGENCE_EMBEDDING_PROVIDER=local

# Optional, only if embedding provider is 'openai'
OPENAI_API_KEY=

# Optional: hard monthly spend cap reminder (informational only)
LP_DILIGENCE_BUDGET_USD=30

# Cache + vectorstore location
LP_DILIGENCE_CACHE_DIR=./data/cache
